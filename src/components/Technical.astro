---
import { Image } from "astro:assets";
const { technical } = Astro.props
---

<article>
    <div class="grid grid-cols-4 p-3.5 rounded-4xl
                max-w-xl max-h-50 min-h-40 ml-3 mr-3
                bg-[#AB81CD]">
        <div class="content-center pr-5">
            <a>
                <Image
                    src={technical.data.image}
                    width={100}
                    height={100/2}
                    alt={technical.data.title}
                    class="rounded-xl mb-4 aspect-thumbnail object-cover"
                    />
            </a>
        </div>
        <div class="col-span-3">
            <a class="text-xl text-zinc-900 font-semibold inline-block">
                <h2>{technical.data.employer}</h2>
            </a>
            <p class="text-[#25283D] text-lg font-semibold">
                {technical.data.title}
            </p>
            <p class="text-[#25283D] text-lg">
                {technical.data.location}
            </p>
            <p class="text-[#25283D] text-lg">
                {technical.data.timeFrame}
            </p>
        </div>
    </div>
</article>