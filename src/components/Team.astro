---
import { Image } from "astro:assets";
const { team } = Astro.props;
---

<article>
    <div class="grid grid-cols-4 p-3.5 rounded-4xl
                max-w-150 min-w-125 max-h-40 min-h-40 justify-center
                bg-[#AB81CD]">
        <div class="content-center pr-5">
            <a>
                <Image
                    src={team.data.image}
                    width={100}
                    height={100 / 2}
                    alt={team.data.title}
                    class="rounded-2xl mb-4 aspect-thumbnail object-cover"
                />
            </a>
        </div>
        <div class="col-span-3">
            <a class="text-xl text-zinc-900 font-semibold inline-block">
                <h2>{team.data.teamName}</h2>
            </a>
            <p class="text-[#25283D] text-lg font-semibold">
                {team.data.title}
            </p>
            <p class="text-[#25283D] text-lg">
                {team.data.timeFrame}
            </p>
        </div>
    </div>
</article>